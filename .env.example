# Copy this file to .env and fill in local or secret values.
# Never put real secrets in .env.example.

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_DOCKER_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=wikimedia.recent_changes
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_EXTERNAL_PORT=9092
KAFKA_IMAGE=bitnamilegacy/kafka:3.7.0
KAFKA_CONTAINER_NAME=streamingetl-kafka
KAFKA_INIT_CONTAINER_NAME=streamingetl-kafka-init
KAFKA_UI_PORT=9091
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_CONTAINER_NAME=streamingetl-kafka-ui
KAFKA_UI_CLUSTER_NAME=local
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_LISTENERS=INTERNAL://:29092,EXTERNAL://:9092,CONTROLLER://:9093
KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka:29092,EXTERNAL://localhost:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_ALLOW_PLAINTEXT_LISTENER=yes
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_HEALTHCHECK_INTERVAL=10s
KAFKA_HEALTHCHECK_TIMEOUT=5s
KAFKA_HEALTHCHECK_RETRIES=10
STREAMINGETL_APP_IMAGE=streamingetl-app:local
# Use 0 when you want the producer to keep streaming until stopped.
PRODUCER_LIMIT=5
SPARK_PREVIEW_LIMIT=5
STREAMLIT_PORT=8501
SPARK_KAFKA_CONNECTOR_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.2
# Optional: set this if Spark should use a specific Java install.
# SPARK_JAVA_HOME=/path/to/java17
SPARK_SQL_SHUFFLE_PARTITIONS=8
SPARK_ADAPTIVE_EXECUTION_ENABLED=true
SPARK_ADAPTIVE_COALESCE_PARTITIONS_ENABLED=true
SPARK_PARTITION_OVERWRITE_MODE=dynamic

# Azure Storage account settings
# Replace these placeholders in .env before writing to Azure.
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account-name>
AZURE_STORAGE_ACCOUNT_KEY=<your-storage-account-key>
# Spark needs this connector to understand abfss:// Azure Storage paths.
SPARK_AZURE_STORAGE_CONNECTOR_PACKAGE=org.apache.hadoop:hadoop-azure:3.4.2

# Bronze layer: raw Kafka data lands here.
AZURE_BRONZE_CONTAINER_NAME=bronze
AZURE_BRONZE_OUTPUT_PATH=wikimedia/recent_changes/raw
AZURE_BRONZE_OUTPUT_FORMAT=parquet
AZURE_BRONZE_WRITE_MODE=append
AZURE_BRONZE_PARTITION_COLUMNS=bronze_ingested_date,kafka_topic
AZURE_BRONZE_CHECKPOINT_PATH=wikimedia/recent_changes/checkpoints/bronze
BRONZE_STREAM_TRIGGER_INTERVAL=30 seconds
KAFKA_STREAM_STARTING_OFFSETS=earliest

# Silver layer: Spark reads Bronze, cleans the data, and writes here.
AZURE_SILVER_CONTAINER_NAME=silver
AZURE_SILVER_OUTPUT_PATH=wikimedia/recent_changes/cleaned
AZURE_SILVER_OUTPUT_FORMAT=parquet
AZURE_SILVER_WRITE_MODE=append
AZURE_SILVER_PARTITION_COLUMNS=event_date

# Quarantine layer: bad records land here instead of disappearing.
AZURE_QUARANTINE_CONTAINER_NAME=quarantine
AZURE_QUARANTINE_OUTPUT_PATH=wikimedia/recent_changes/bad_records
AZURE_QUARANTINE_OUTPUT_FORMAT=parquet
AZURE_QUARANTINE_WRITE_MODE=append
AZURE_QUARANTINE_PARTITION_COLUMNS=processing_window_date,quality_error_category

# Gold layer: Spark reads Silver, builds star-schema models, and writes here.
AZURE_GOLD_CONTAINER_NAME=gold
AZURE_GOLD_OUTPUT_PATH=wikimedia/recent_changes/star_schema
AZURE_GOLD_OUTPUT_FORMAT=parquet
AZURE_GOLD_WRITE_MODE=overwrite
# Optional table-level partitions. Facts are partitioned by event_date by default.
# AZURE_GOLD_DIM_DATE_PARTITION_COLUMNS=
# AZURE_GOLD_DIM_WIKI_PARTITION_COLUMNS=
# AZURE_GOLD_DIM_PAGE_PARTITION_COLUMNS=
# AZURE_GOLD_DIM_USER_PARTITION_COLUMNS=
# AZURE_GOLD_DIM_EVENT_TYPE_PARTITION_COLUMNS=
# AZURE_GOLD_FACT_RECENT_CHANGES_PARTITION_COLUMNS=event_date
# AZURE_GOLD_AGG_EVENTS_BY_DATE_PARTITION_COLUMNS=event_date
# AZURE_GOLD_AGG_EVENTS_BY_WINDOW_PARTITION_COLUMNS=event_date
# AZURE_GOLD_RECENT_EVENTS_SNAPSHOT_PARTITION_COLUMNS=event_date

# Data quality, backfills, and late-arriving data.
DATA_QUALITY_STRICT_MODE=false
LATE_ARRIVAL_DAYS=2
AIRFLOW_SILVER_LOOKBACK_DAYS=
AIRFLOW_SILVER_WRITE_MODE=overwrite
AIRFLOW_GOLD_WRITE_MODE=overwrite

# Airflow UI
AIRFLOW_IMAGE=streamingetl-airflow:local
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_TRANSFORM_SCHEDULE=*/5 * * * *
AIRFLOW_DAGS_ARE_PAUSED_AT_CREATION=false
AIRFLOW_DASHBOARD_HEALTHCHECK_ENABLED=true
DASHBOARD_HEALTH_URL=http://dashboard:8501/_stcore/health
DASHBOARD_MIN_FACT_ROWS=1
DASHBOARD_DEFAULT_TOP_N=10
DASHBOARD_MAX_TOP_N=30
DASHBOARD_DEFAULT_RECENT_ROWS=25
DASHBOARD_MAX_RECENT_ROWS=100
DASHBOARD_STALE_AFTER_MINUTES=30
DASHBOARD_SHOW_DEBUG_ERRORS=false
DASHBOARD_STREAMLIT_CACHE_TTL_SECONDS=300

# Redis cache for the Streamlit dashboard.
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=streamingetl-redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=streamingetl
REDIS_CACHE_TTL_SECONDS=300
REDIS_CONNECT_TIMEOUT_SECONDS=1
REDIS_SOCKET_TIMEOUT_SECONDS=2
DASHBOARD_CACHE_VERSION=v1

WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
WIKIMEDIA_USER_AGENT="StreamingETL/0.1 (educational ETL pipeline)"

# Uncomment these if you later connect to a secured Kafka cluster.
# KAFKA_USERNAME=
# KAFKA_PASSWORD=
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
